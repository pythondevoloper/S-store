// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: products
// Document ID: productId
// Fields:
//   - name: string (required)
//   - category: string (required)
//   - price: number (required)
//   - dynamicPrice: number (optional)
//   - groupPrice: number (optional)
//   - isTrending: boolean (optional)
//   - viewCount: number (optional)
//   - image: string (required)
//   - description: string (required)
//   - specs: map (optional)
//   - stockQuantity: number (required)
//   - 3dModelUrl: string (optional)
//
// Subcollection: products/{productId}/reviews
// Document ID: reviewId
// Fields:
//   - userName: string (required)
//   - rating: number (required, 1-5)
//   - comment: string (required, < 1000 chars)
//   - reviewImage: string (optional)
//   - videoUrl: string (optional)
//   - createdAt: timestamp (required)
//
// Collection: orders
// Document ID: orderId
// Fields:
//   - customerName: string (required)
//   - phone: string (required)
//   - email: string (required)
//   - address: string (required)
//   - items: list (required)
//   - total: number (required)
//   - status: string (required, enum)
//   - createdAt: timestamp (required)
//   - giftWrapping: boolean (optional)
//   - greetingCard: string (optional)
//   - groupId: string (optional)
//
// Collection: users
// Document ID: userId (auth.uid)
// Fields:
//   - email: string (required)
//   - role: string (required, enum)
//   - affiliateBalance: number (optional)
//   - affiliateToken: string (optional)
//   - userLevel: string (optional)
//   - totalSpent: number (optional)
//   - orderCount: number (optional)
//
// Collection: promocodes
// Document ID: promoId
// Fields:
//   - code: string (required)
//   - discountPercentage: number (required)
//   - expiryDate: string (optional)
//   - isActive: boolean (required)
//
// Collection: settings
// Document ID: global
// Fields:
//   - logoBase64: string (optional)
//   - cardNumber: string (optional)
//   - cardName: string (optional)
//   - paymentType: string (optional)
//   - walletNumber: string (optional)
//   - walletName: string (optional)
//   - bots: list (optional)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'SuperAdmin'] ||
          (request.auth.token.email == "computeruz559@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SuperAdmin' ||
          (request.auth.token.email == "computeruz559@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.category is string &&
             data.price is number && data.price >= 0 &&
             data.image is string &&
             data.description is string && data.description.size() < 5000 &&
             data.stockQuantity is number && data.stockQuantity >= 0;
    }

    function isValidReview(data) {
      return data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 1000 &&
             data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.email is string &&
             data.total is number && data.total >= 0 &&
             data.status in ["Pending", "Paid", "Processing", "Shipped", "Delivered", "Rejected", "Awaiting Approval", "Pending Payment", "Awaiting Payment"] &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.email is string &&
             data.role in ["User", "Admin", "SuperAdmin"];
    }

    function isValidPromoCode(data) {
      return data.code is string && data.code.size() > 0 &&
             data.discountPercentage is number && data.discountPercentage >= 0 && data.discountPercentage <= 100 &&
             data.isActive is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidReview(request.resource.data);
        allow update, delete: if isAdmin();
      }
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.email);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'User';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isSuperAdmin();
    }

    match /promocodes/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
