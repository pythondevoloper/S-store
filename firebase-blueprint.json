{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer order in the S STORE.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID (e.g., #S-1234)" },
        "customerName": { "type": "string", "description": "Full name of the customer" },
        "email": { "type": "string", "description": "Email address of the customer" },
        "phone": { "type": "string", "description": "Phone number of the customer" },
        "address": { "type": "string", "description": "Shipping address" },
        "paymentMethod": { "type": "string", "description": "Selected payment method" },
        "promoCode": { "type": "string", "description": "Applied promo code" },
        "total": { "type": "number", "description": "Total amount in USD" },
        "testMode": { "type": "boolean", "description": "Whether the order is in test mode" },
        "giftWrapping": { "type": "boolean", "description": "Whether gift wrapping is requested" },
        "greetingCard": { "type": "string", "description": "Greeting card message" },
        "groupId": { "type": "string", "description": "Group buy ID if applicable" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "ref": { "type": "string", "description": "Referral token" },
        "exchangeRateUsed": { "type": "number", "description": "Exchange rate at the time of order" },
        "status": { "type": "string", "description": "Current status of the order", "enum": ["Awaiting Payment", "Paid", "Cancelled", "Shipped", "Delivered"] },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the order was created" }
      },
      "required": ["id", "customerName", "email", "phone", "address", "total", "items", "status", "createdAt"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
